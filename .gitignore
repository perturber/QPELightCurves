# ========================
# qpenn Project Specific
# ========================
# Ignore downloaded massive FITS/ARF data files
downloads/

# ========================
# Python Caches & Build 
# ========================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging autogenerated folders
build/
dist/
*.egg-info/
.eggs/

# ========================
# Jupyter Notebooks
# ========================
# Ignore notebook autosaves and checkpoints
.ipynb_checkpoints/

# ========================
# Virtual Environments
# ========================
# Just in case you ever create a local venv inside the folder
venv/
env/
.env